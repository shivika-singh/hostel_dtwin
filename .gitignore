simulator/venv/

# Large generated files
simulator/training_data.csv
simulator/lstm_model.keras
simulator/temp_*.json

# Node modules
node_modules/
*/node_modules/
*/*/node_modules/

# Python cache
__pycache__/
*.pyc
*.pyo

# Mac files
.DS_Store

# Training artifacts
simulator/scaler_params.json
